modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Apollo Scraper Server"

[[workflows.workflow]]
name = "Apollo Scraper Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd app && python -m uvicorn main:app --host 0.0.0.0 --port 5000 --reload"
waitForPort = 5000

[deployment]
run = ["sh", "-c", "cd app && python -m uvicorn main:app --host 0.0.0.0 --port 5000 --reload"]
